# Google Gemini API Key (Primary)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Google Gemini API Key (Optional — Secondary fallback for quota resilience)
# If primary key hits 429 rate-limit, the app automatically cascades to this key
GEMINI_API_KEY_2=

# Google Maps API Key (server-side — for Places API)
# Enable: Places API, Maps JavaScript API
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# Google Cloud Translation API Key
# Enable: Cloud Translation API
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_TRANSLATE_API_KEY=

# Google Maps Public Key (client-side — only Maps JS API, restricted by referrer)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
